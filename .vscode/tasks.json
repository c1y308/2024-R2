{
    "version": "2.0.0",
    "tasks": [
        {
            "label": "C/C++: gcc.exe 生成活动文件",
            "type": "shell",
            "command": "D:\\A-StudySoft\\mingw64\\bin\\g++.exe",
            "args": [
                "-fdiagnostics-color=always",
                "-g", // 生成调试信息，调试必需
                "${file}", // 要编译的当前活动文件
                "-o", // 指定输出文件
                "${fileDirname}\\\\${fileBasenameNoExtension}.exe", // 输出的可执行文件路径
                "-static-libgcc",
                "-fexec-charset=GBK" // 解决Windows终端中文乱码问题:cite[3]:cite[5]
            ],
            "group": {
                "kind": "build",
                "isDefault": true // 设为默认生成任务，可用Ctrl+Shift+B直接运行
            },
            "problemMatcher": ["$gcc"],
            "detail": "编译器: D:/software/mingw64/bin/gcc.exe" // 请修改为你的gcc路径
        }
    ]
}